#!/usr/bin/env bash
# pre-push — pytest must pass before a push is allowed.
# Installed via: git config core.hooksPath .githooks

# Run a private, untracked local hook first if present — .git/hooks/ is
# never read by git itself while core.hooksPath points here, so this is
# the one place a personal hook (e.g. a branch-push guard) can live
# without being published alongside the hooks in this directory. Runs
# before the checks below so a fast personal guard can reject a push
# without waiting on the test suite.
LOCAL_HOOK="$(git rev-parse --git-dir)/hooks/$(basename "$0")"
if [ -x "$LOCAL_HOOK" ]; then
    "$LOCAL_HOOK" "$@" || exit $?
fi

# switch to shng root dir for checks/tests to run properly
SHNG_DIR="$(git rev-parse --show-toplevel)"
cd "$SHNG_DIR" || exit 1

PYTEST="${SHNG_DIR}/venvs/shng/bin/pytest"
[ -x "$PYTEST" ] || PYTEST="pytest"

echo ""
echo "── pre-push gate (shng) ────────────────────────────────────────"
echo "  running tests/ ..."
echo ""

if ! "$PYTEST" tests/ --tb=short -q; then
    echo ""
    echo "==> PUSH REJECTED: tests failed."
    echo ""
    echo "    Fix failing tests, then:  git push"
    echo "    Bypass (use sparingly):   git push --no-verify"
    echo ""
    echo "    Note: pytest is a required CI check — failures will block your PR."
    echo "────────────────────────────────────────────────────────────────"
    echo ""
    exit 1
fi

echo "  pytest: OK"
echo "────────────────────────────────────────────────────────────────"
echo ""
