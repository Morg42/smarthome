#!/usr/bin/env bash
# pre-push — ruff + pytest must both pass before a push is allowed.
# Exit 1 to reject the push; Git prints "error: failed to push some refs" in that case.

SHNG_DIR="$(git rev-parse --show-toplevel)"
cd "$SHNG_DIR" || exit 1

RUFF="${SHNG_DIR}/venvs/shng/bin/ruff"
[ -x "$RUFF" ] || RUFF="ruff"
PYTEST="${SHNG_DIR}/venvs/shng/bin/pytest"
[ -x "$PYTEST" ] || PYTEST="pytest"

echo ""
echo "── pre-push gate (shng) ────────────────────────────────────────"

if ! "$RUFF" check lib/ tests/ bin/ modules/ tools/; then
    echo ""
    echo "  PUSH REJECTED: fix ruff errors first ('ruff check lib/ tests/ bin/ modules/ tools/')"
    echo "────────────────────────────────────────────────────────────────"
    echo ""
    exit 1
fi
echo "  ruff  : OK"

if ! "$PYTEST" --tb=short -q; then
    echo ""
    echo "  PUSH REJECTED: fix failing tests first"
    echo "────────────────────────────────────────────────────────────────"
    echo ""
    exit 1
fi
echo "  pytest: OK"

echo "────────────────────────────────────────────────────────────────"
echo ""
